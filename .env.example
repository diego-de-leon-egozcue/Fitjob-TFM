# Ruta manual al binario de Claude (opcional)
# Si no se pone, se detecta automáticamente desde ~/.vscode/extensions/anthropic.claude-code-*/
# CLAUDE_BIN=C:\Users\TuUsuario\.vscode\extensions\anthropic.claude-code-X.X.X\resources\native-binary\claude.exe

# Gmail para envío de documentos al usuario (opcional)
# Usar una "Contraseña de aplicación" de Google, no la contraseña normal
# Ver: https://myaccount.google.com/apppasswords
FITJOB_GMAIL_USER=fitjob@gmail.com
FITJOB_GMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
